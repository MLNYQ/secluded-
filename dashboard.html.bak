<!DOCTYPE html>
<html lang="zh-CN" data-theme="dark">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
	<title>Secluded Bot</title>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
	<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
	<style>
		:root {
			--bg-body: #0d1117;
			--bg-sidebar: #161b22;
			--bg-header: rgba(13,17,23,0.95);
			--bg-card: #161b22;
			--bg-input: #0d1117;
			--text-primary: #e6edf3;
			--text-secondary: #7d8590;
			--text-muted: #484f58;
			--accent: #58a6ff;
			--accent-hover: #79b8ff;
			--accent-success: #3fb950;
			--accent-warning: #d29922;
			--accent-danger: #f85149;
			--border: #30363d;
			--border-hover: #8b949e;
			--shadow: 0 8px 24px rgba(0,0,0,0.5);
			--radius: 12px;
			--sidebar-w: 260px;
			--header-h: 56px;
		}
		[data-theme="light"] {
			--bg-body: #f6f8fa;
			--bg-sidebar: #ffffff;
			--bg-header: rgba(255,255,255,0.95);
			--bg-card: #ffffff;
			--bg-input: #f6f8fa;
			--text-primary: #1f2328;
			--text-secondary: #656d76;
			--text-muted: #afb8c1;
			--accent: #0969da;
			--accent-hover: #0550ae;
			--border: #d0d7de;
			--border-hover: #8c959f;
			--shadow: 0 8px 24px rgba(31,35,40,0.08);
		}
		* { margin: 0; padding: 0; box-sizing: border-box; }
		body {
			font-family: 'Inter', -apple-system, sans-serif;
			background: var(--bg-body);
			color: var(--text-primary);
			min-height: 100vh;
			overflow: hidden;
		}
		.sidebar {
			position: fixed;
			left: 0; top: 0;
			width: var(--sidebar-w);
			height: 100vh;
			background: var(--bg-sidebar);
			border-right: 1px solid var(--border);
			display: flex;
			flex-direction: column;
			z-index: 200;
			transition: transform 0.3s ease;
		}
		.sidebar-brand {
			padding: 20px 20px 12px;
			display: flex;
			align-items: center;
			gap: 12px;
			border-bottom: 1px solid var(--border);
		}
		.sidebar-brand-icon {
			width: 36px; height: 36px;
			background: linear-gradient(135deg, var(--accent), var(--accent-hover));
			border-radius: 10px;
			display: flex; align-items: center; justify-content: center;
			color: #fff; font-size: 18px;
		}
		.sidebar-brand-text {
			font-size: 18px; font-weight: 700;
			letter-spacing: -0.5px;
		}
		.sidebar-brand-version {
			font-size: 10px; padding: 1px 6px;
			background: var(--bg-body); color: var(--text-secondary);
			border-radius: 10px; border: 1px solid var(--border);
			margin-left: auto;
		}
		.sidebar-nav {
			flex: 1;
			padding: 12px 10px;
			overflow-y: auto;
		}
		.nav-group-label {
			font-size: 11px; font-weight: 600;
			color: var(--text-muted);
			text-transform: uppercase;
			letter-spacing: 0.8px;
			padding: 16px 12px 8px;
		}
		.nav-item {
			display: flex; align-items: center; gap: 12px;
			padding: 10px 14px;
			border-radius: 8px;
			cursor: pointer;
			font-size: 14px; font-weight: 500;
			color: var(--text-secondary);
			transition: all 0.15s ease;
			margin-bottom: 2px;
			border: none; background: none; width: 100%;
			text-align: left;
		}
		.nav-item:hover {
			background: rgba(88,166,255,0.08);
			color: var(--text-primary);
		}
		.nav-item.active {
			background: rgba(88,166,255,0.12);
			color: var(--accent);
			font-weight: 600;
		}
		.nav-item i { width: 20px; text-align: center; font-size: 15px; }
		.nav-badge {
			margin-left: auto;
			font-size: 11px; padding: 1px 7px;
			background: var(--accent-danger); color: #fff;
			border-radius: 10px; font-weight: 600;
		}
		.sidebar-footer {
			padding: 12px 16px;
			border-top: 1px solid var(--border);
			font-size: 12px;
			color: var(--text-muted);
			display: flex;
			align-items: center;
			gap: 8px;
		}
		.sidebar-footer .status-dot {
			width: 8px; height: 8px; border-radius: 50%;
			background: var(--accent-success);
			box-shadow: 0 0 6px var(--accent-success);
			animation: pulse 2s infinite;
		}
		.sidebar-footer .status-dot.offline {
			background: var(--accent-danger);
			box-shadow: none; animation: none;
		}
		.header {
			position: fixed;
			left: var(--sidebar-w); top: 0; right: 0;
			height: var(--header-h);
			background: var(--bg-header);
			backdrop-filter: blur(12px);
			border-bottom: 1px solid var(--border);
			display: flex; align-items: center;
			justify-content: space-between;
			padding: 0 24px;
			z-index: 100;
		}
		.header-title {
			font-size: 18px; font-weight: 600;
			display: flex; align-items: center; gap: 10px;
		}
		.header-title i { color: var(--accent); font-size: 16px; }
		.header-actions { display: flex; gap: 8px; align-items: center; }
		.header-btn {
			width: 34px; height: 34px;
			border-radius: 8px; border: 1px solid var(--border);
			background: transparent; color: var(--text-secondary);
			cursor: pointer; display: flex;
			align-items: center; justify-content: center;
			transition: all 0.15s ease;
		}
		.header-btn:hover {
			background: var(--bg-card);
			color: var(--text-primary);
			border-color: var(--border-hover);
		}
		.menu-toggle {
			display: none;
			width: 34px; height: 34px;
			border-radius: 8px; border: 1px solid var(--border);
			background: transparent; color: var(--text-secondary);
			cursor: pointer; align-items: center; justify-content: center;
		}
		.main {
			position: fixed;
			left: var(--sidebar-w); top: var(--header-h);
			right: 0; bottom: 0;
			overflow-y: auto;
			padding: 24px;
		}
		.page { display: none; animation: fadeIn 0.2s ease; }
		.page.active { display: block; }
		@keyframes fadeIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
		@keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.5; } }
		.card {
			background: var(--bg-card);
			border: 1px solid var(--border);
			border-radius: var(--radius);
			box-shadow: var(--shadow);
			margin-bottom: 20px;
			overflow: hidden;
		}
		.card-header {
			padding: 16px 20px;
			border-bottom: 1px solid var(--border);
			display: flex; align-items: center; justify-content: space-between;
			background: rgba(255,255,255,0.02);
		}
		.card-title {
			font-size: 15px; font-weight: 600;
			display: flex; align-items: center; gap: 10px;
		}
		.card-title i { color: var(--accent); font-size: 16px; }
		.card-content { padding: 20px; }
		.card-badge {
			font-size: 11px; padding: 2px 8px;
			background: var(--accent); color: #fff;
			border-radius: 20px; font-weight: 600;
		}
		.input-group { display: flex; gap: 8px; margin-bottom: 12px; }
		.input-field {
			flex: 1;
			padding: 10px 14px;
			background: var(--bg-input);
			border: 1px solid var(--border);
			border-radius: 8px;
			color: var(--text-primary);
			font-size: 14px;
			font-family: 'JetBrains Mono', monospace;
			transition: all 0.15s ease;
		}
		.input-field:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(88,166,255,0.1); }
		.input-field::placeholder { color: var(--text-muted); }
		.textarea-field {
			width: 100%; min-height: 80px;
			padding: 12px 14px;
			background: var(--bg-input);
			border: 1px solid var(--border);
			border-radius: 8px;
			color: var(--text-primary);
			font-size: 14px; resize: vertical;
			transition: all 0.15s ease;
			margin-bottom: 12px;
		}
		.textarea-field:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(88,166,255,0.1); }
		.btn {
			display: inline-flex; align-items: center; justify-content: center;
			gap: 8px; padding: 10px 16px;
			border-radius: 8px; font-size: 13px; font-weight: 600;
			cursor: pointer; transition: all 0.15s ease;
			border: none; white-space: nowrap;
		}
		.btn-primary { background: var(--accent); color: #fff; }
		.btn-primary:hover { background: var(--accent-hover); transform: translateY(-1px); }
		.btn-secondary { background: var(--bg-input); color: var(--text-primary); border: 1px solid var(--border); }
		.btn-secondary:hover { background: var(--border); }
		.btn-danger { background: rgba(248,81,73,0.1); color: var(--accent-danger); border: 1px solid rgba(248,81,73,0.2); }
		.btn-danger:hover { background: rgba(248,81,73,0.2); }
		.btn-icon {
			width: 28px; height: 28px; border: none;
			background: transparent; color: var(--text-secondary);
			cursor: pointer; border-radius: 6px;
			display: flex; align-items: center; justify-content: center;
			transition: all 0.15s ease;
		}
		.btn-icon:hover { background: rgba(248,81,73,0.1); color: var(--accent-danger); }
		.list-container { display: flex; flex-direction: column; gap: 6px; }
		.list-item {
			display: flex; align-items: center; justify-content: space-between;
			padding: 10px 14px;
			background: var(--bg-input);
			border-radius: 8px;
			border: 1px solid var(--border);
			transition: all 0.15s ease;
		}
		.list-item:hover { border-color: var(--border-hover); }
		.list-item-info { display: flex; align-items: center; gap: 10px; }
		.list-item-icon {
			width: 30px; height: 30px;
			background: var(--bg-sidebar);
			border-radius: 6px;
			display: flex; align-items: center; justify-content: center;
			color: var(--text-secondary); font-size: 12px;
		}
		.list-item-text { font-family: 'JetBrains Mono', monospace; font-size: 13px; }
		.plugin-list { display: flex; flex-direction: column; gap: 8px; }
		.plugin-item {
			display: flex; align-items: center; justify-content: space-between;
			padding: 14px 16px;
			background: var(--bg-input);
			border-radius: 10px;
			border: 1px solid var(--border);
			transition: all 0.15s ease;
		}
		.plugin-item:hover { border-color: var(--accent); }
		.plugin-info { display: flex; align-items: center; gap: 12px; }
		.plugin-icon {
			width: 36px; height: 36px;
			background: rgba(88,166,255,0.1);
			border-radius: 8px;
			display: flex; align-items: center; justify-content: center;
			color: var(--accent); font-size: 14px;
		}
		.plugin-name { font-weight: 600; font-size: 14px; font-family: 'JetBrains Mono', monospace; }
		.plugin-meta { font-size: 12px; color: var(--text-secondary); margin-top: 2px; }
		.plugin-controls { display: flex; align-items: center; gap: 12px; }
		.toggle { position: relative; width: 40px; height: 22px; }
		.toggle input { opacity: 0; width: 0; height: 0; }
		.toggle-slider {
			position: absolute; cursor: pointer;
			top: 0; left: 0; right: 0; bottom: 0;
			background: var(--bg-sidebar);
			border-radius: 22px;
			transition: 0.2s;
			border: 1px solid var(--border);
		}
		.toggle-slider:before {
			position: absolute; content: "";
			height: 16px; width: 16px;
			left: 2px; bottom: 2px;
			background: white; border-radius: 50%;
			transition: 0.2s;
		}
		input:checked + .toggle-slider { background: var(--accent); border-color: var(--accent); }
		input:checked + .toggle-slider:before { transform: translateX(18px); }
		.admin-toggle {
			display: flex; align-items: center; gap: 6px;
			font-size: 12px; color: var(--text-secondary);
			cursor: pointer; padding: 4px 8px;
			border-radius: 6px; transition: all 0.15s ease;
		}
		.admin-toggle:hover { background: var(--bg-sidebar); color: var(--accent-warning); }
		.log-container {
			background: #0a0c10;
			border-radius: 8px;
			padding: 16px;
			font-family: 'JetBrains Mono', monospace;
			font-size: 12px; line-height: 1.7;
			height: calc(100vh - 220px);
			overflow-y: auto;
			color: #e6edf3;
			border: 1px solid var(--border);
		}
		.log-container::-webkit-scrollbar { width: 6px; }
		.log-container::-webkit-scrollbar-thumb { background: var(--border); border-radius: 3px; }
		.log-line { margin-bottom: 2px; }
		.log-time { color: var(--text-muted); }
		.log-info { color: var(--accent); }
		.log-warn { color: var(--accent-warning); }
		.log-error { color: var(--accent-danger); }
		.log-success { color: var(--accent-success); }
		.chat-container {
			background: #0a0c10;
			border-radius: 8px;
			padding: 16px;
			height: calc(100vh - 280px);
			overflow-y: auto;
			border: 1px solid var(--border);
			font-size: 14px; line-height: 1.6;
			margin-bottom: 12px;
		}
		.chat-msg { margin-bottom: 12px; padding: 10px 14px; border-radius: 8px; max-width: 85%; }
		.chat-msg.user { background: rgba(88,166,255,0.1); border: 1px solid rgba(88,166,255,0.2); margin-left: auto; }
		.chat-msg.ai { background: var(--bg-sidebar); border: 1px solid var(--border); }
		.chat-msg .sender { font-size: 11px; font-weight: 600; margin-bottom: 4px; color: var(--accent); }
		.chat-msg.user .sender { color: var(--accent); }
		.chat-msg.ai .sender { color: var(--accent-success); }
		.chat-input-row { display: flex; gap: 10px; }
		.chat-input-row .input-field { flex: 1; }
		.status-grid {
			display: grid;
			grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
			gap: 12px;
			margin-bottom: 20px;
		}
		.status-card {
			background: var(--bg-card);
			border: 1px solid var(--border);
			border-radius: var(--radius);
			padding: 16px 20px;
			display: flex; align-items: center; gap: 14px;
			transition: all 0.15s ease;
		}
		.status-card:hover { border-color: var(--border-hover); }
		.status-card-icon {
			width: 40px; height: 40px;
			border-radius: 10px;
			display: flex; align-items: center; justify-content: center;
			font-size: 18px;
		}
		.status-card-icon.blue { background: rgba(88,166,255,0.1); color: var(--accent); }
		.status-card-icon.green { background: rgba(63,185,80,0.1); color: var(--accent-success); }
		.status-card-icon.orange { background: rgba(210,153,34,0.1); color: var(--accent-warning); }
		.status-card-icon.gray { background: rgba(125,133,144,0.1); color: var(--text-secondary); }
		.status-card-label { font-size: 12px; color: var(--text-secondary); margin-bottom: 2px; }
		.status-card-value { font-size: 18px; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
		.empty-state { text-align: center; padding: 40px; color: var(--text-muted); }
		.empty-state i { font-size: 40px; margin-bottom: 12px; }
		.empty-state p { font-size: 13px; }
		.toast {
			position: fixed; bottom: 24px; right: 24px;
			padding: 12px 20px;
			background: var(--bg-card);
			border: 1px solid var(--border);
			border-radius: 10px;
			box-shadow: var(--shadow);
			display: flex; align-items: center; gap: 10px;
			font-size: 14px; z-index: 1000;
			transform: translateY(100px); opacity: 0;
			transition: all 0.3s ease;
		}
		.toast.show { transform: translateY(0); opacity: 1; }
		.toast-success { color: var(--accent-success); }
		.toast-error { color: var(--accent-danger); }
		.qq-avatar {
			width: 40px; height: 40px;
			border-radius: 50%;
			object-fit: cover;
			border: 2px solid var(--border);
			background: var(--bg-input);
		}
		.qq-avatar-lg {
			width: 72px; height: 72px;
			border-radius: 50%;
			object-fit: cover;
			border: 3px solid var(--accent);
			background: var(--bg-input);
		}
		.profile-card {
			display: flex; align-items: center; gap: 16px;
			padding: 20px;
			background: var(--bg-card);
			border: 1px solid var(--border);
			border-radius: var(--radius);
			margin-bottom: 20px;
		}
		.profile-info h3 {
			font-size: 18px; font-weight: 600; margin-bottom: 4px;
		}
		.profile-info p {
			font-size: 13px; color: var(--text-secondary); font-family: 'JetBrains Mono', monospace;
		}
		.update-info {
			display: flex; flex-direction: column; gap: 16px;
		}
		.update-row {
			display: flex; justify-content: space-between;
			align-items: center;
			padding: 14px 16px;
			background: var(--bg-input);
			border-radius: 8px;
			border: 1px solid var(--border);
		}
		.update-row-label { font-size: 13px; color: var(--text-secondary); }
		.update-row-value { font-size: 14px; font-weight: 600; font-family: 'JetBrains Mono', monospace; }
		.update-changelog {
			background: var(--bg-input);
			border: 1px solid var(--border);
			border-radius: 8px;
			padding: 16px;
			font-size: 14px;
			line-height: 1.8;
			color: var(--text-secondary);
			max-height: 400px;
			overflow-y: auto;
		}
		.update-changelog h4 {
			color: var(--text-primary);
			margin-bottom: 8px;
			font-size: 14px;
		}
		.update-changelog ul {
			padding-left: 20px;
			margin-bottom: 12px;
		}
		.update-changelog li {
			margin-bottom: 4px;
		}
		.update-status-badge {
			display: inline-flex; align-items: center; gap: 6px;
			padding: 4px 12px;
			border-radius: 20px;
			font-size: 12px; font-weight: 600;
		}
		.update-status-badge.up-to-date {
			background: rgba(63,185,80,0.1); color: var(--accent-success); border: 1px solid rgba(63,185,80,0.2);
		}
		.update-status-badge.has-update {
			background: rgba(210,153,34,0.1); color: var(--accent-warning); border: 1px solid rgba(210,153,34,0.2);
		}
		.preview-box {
			background: var(--bg-input);
			border: 1px solid var(--border);
			border-radius: 8px;
			padding: 8px 12px;
			margin-top: 6px;
			font-size: 13px;
			color: var(--text-secondary);
			font-family: 'JetBrains Mono', monospace;
			word-break: break-all;
			min-height: 28px;
		}
		.preview-box:empty::before {
			content: "输入预览区，实时显示发送内容";
			color: var(--text-muted);
		}
		@media (max-width: 768px) {
			.sidebar { transform: translateX(-100%); }
			.sidebar.open { transform: translateX(0); }
			.main, .header { left: 0; }
			.menu-toggle { display: flex; }
			.header { padding: 0 16px; }
			.main { padding: 16px; }
			.log-container, .chat-container { height: 50vh; }
			.input-group { flex-wrap: wrap; }
			.input-field { width: 100%; }
			.btn { width: 100%; }
			.plugin-item { flex-wrap: wrap; gap: 10px; }
			.plugin-controls { width: 100%; justify-content: flex-end; }
			.profile-card { flex-direction: column; text-align: center; }
		}
		.overlay {
			display: none;
			position: fixed; inset: 0;
			background: rgba(0,0,0,0.5);
			z-index: 150;
		}
		.overlay.show { display: block; }
	</style>
</head>
<body>
	<div class="overlay" id="overlay" onclick="toggleSidebar()"></div>

	<aside class="sidebar" id="sidebar">
		<div class="sidebar-brand">
			<div class="sidebar-brand-icon"><i class="fas fa-robot"></i></div>
			<div class="sidebar-brand-text">Secluded Bot</div>
			<span class="sidebar-brand-version" id="sidebar-version">--</span>
		</div>
		<nav class="sidebar-nav">
			<div class="nav-group-label">概览</div>
			<button class="nav-item active" onclick="switchPage('dashboard')" data-page="dashboard">
				<i class="fas fa-chart-line"></i>仪表盘
			</button>
			<button class="nav-item" onclick="switchPage('plugins')" data-page="plugins">
				<i class="fas fa-puzzle-piece"></i>插件管理
				<span class="nav-badge" id="nav-plugin-badge">0</span>
			</button>
			<button class="nav-item" onclick="switchPage('logs')" data-page="logs">
				<i class="fas fa-terminal"></i>实时日志
			</button>
			<div class="nav-group-label">管理</div>
			<button class="nav-item" onclick="switchPage('accounts')" data-page="accounts">
				<i class="fas fa-users-cog"></i>账号管理
			</button>
			<button class="nav-item" onclick="switchPage('permissions')" data-page="permissions">
				<i class="fas fa-shield-alt"></i>权限控制
			</button>
			<button class="nav-item" onclick="switchPage('send')" data-page="send">
				<i class="fas fa-paper-plane"></i>快速发信
			</button>
			<div class="nav-group-label">工具</div>
			<button class="nav-item" onclick="switchPage('ai')" data-page="ai">
				<i class="fas fa-comment-dots"></i>AI 助手
			</button>
			<button class="nav-item" onclick="switchPage('update')" data-page="update">
				<i class="fas fa-sync-alt"></i>检查更新
			</button>
		</nav>
		<div class="sidebar-footer">
			<div class="status-dot online" id="sidebar-status-dot"></div>
			<span id="sidebar-status-text">在线</span>
			<span style="margin-left:auto; font-family:monospace;" id="sidebar-qq">--</span>
		</div>
	</aside>

	<header class="header">
		<div style="display:flex;align-items:center;gap:12px;">
			<button class="menu-toggle" onclick="toggleSidebar()"><i class="fas fa-bars"></i></button>
			<div class="header-title" id="header-title"><i class="fas fa-chart-line"></i>仪表盘</div>
		</div>
		<div class="header-actions">
			<button class="header-btn" onclick="toggleTheme()" title="切换主题"><i class="fas fa-sun" id="theme-icon"></i></button>
		</div>
	</header>

	<main class="main">
		<div class="page active" id="page-dashboard">
			<div class="status-grid" id="account-list"></div>
			<div class="card">
				<div class="card-header"><div class="card-title"><i class="fas fa-info-circle"></i>关于</div></div>
				<div class="card-content">
					<p style="color:var(--text-secondary);font-size:14px;line-height:1.8;">
						多账号 Secluded 机器人管理面板
					</p>
				</div>
			</div>
		</div>

		<div class="page" id="page-accounts">
			<div class="card">
				<div class="card-header"><div class="card-title"><i class="fas fa-plus-circle"></i>添加机器人</div></div>
				<div class="card-content">
					<div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
						<input type="text" class="input-field" id="add-qq" placeholder="机器人QQ号 *">
						<input type="text" class="input-field" id="add-ws" placeholder="WebSocket地址 *">
						<input type="text" class="input-field" id="add-token" placeholder="Token *">
						<input type="text" class="input-field" id="add-pid" placeholder="Plugin ID">
						<input type="text" class="input-field" id="add-name" placeholder="Plugin Name">
						<input type="text" class="input-field" id="add-group" placeholder="目标群号">
					</div>
					<button class="btn btn-primary" onclick="addAccount()" style="width:100%; margin-top:12px;"><i class="fas fa-check"></i>添加账号</button>
				</div>
			</div>
			<div class="card">
				<div class="card-header"><div class="card-title"><i class="fas fa-robot"></i>已添加账号</div></div>
				<div class="card-content">
					<div class="list-container" id="account-list-container"><div class="empty-state"><p>暂无账号</p></div></div>
				</div>
			</div>
		</div>

		<div class="page" id="page-plugins">
			<div class="card">
				<div class="card-header">
					<div class="card-title"><i class="fas fa-puzzle-piece"></i>插件管理</div>
					<div style="display:flex;align-items:center;gap:12px;">
						<select id="plugin-qq-select" onchange="switchPluginAccount()" style="padding:6px 10px;background:var(--bg-input);border:1px solid var(--border);color:var(--text-primary);border-radius:6px;"></select>
						<span class="card-badge" id="plugin-badge">0</span>
					</div>
				</div>
				<div class="card-content">
					<div class="plugin-list" id="plugin-list"><div class="empty-state"><i class="fas fa-spinner fa-spin"></i><p>加载中...</p></div></div>
				</div>
			</div>
		</div>

		<div class="page" id="page-permissions">
			<div class="card">
				<div class="card-header"><div class="card-title"><i class="fas fa-crown" style="color:var(--accent-warning)"></i>管理员列表</div></div>
				<div class="card-content">
					<div class="input-group">
						<input type="text" class="input-field" id="new_admin" placeholder="输入QQ号...">
						<button class="btn btn-primary" onclick="addAdmin()"><i class="fas fa-plus"></i>添加</button>
					</div>
					<div class="list-container" id="admin-list"></div>
				</div>
			</div>
			<div class="card">
				<div class="card-header"><div class="card-title"><i class="fas fa-user-slash" style="color:var(--accent-danger)"></i>用户黑名单</div></div>
				<div class="card-content">
					<div class="input-group">
						<input type="text" class="input-field" id="new_user_black" placeholder="输入QQ号...">
						<button class="btn btn-danger" onclick="addUserBlack()"><i class="fas fa-ban"></i>拉黑</button>
					</div>
					<div class="list-container" id="user-blacklist"></div>
				</div>
			</div>
			<div class="card">
				<div class="card-header"><div class="card-title"><i class="fas fa-users-slash" style="color:var(--accent-danger)"></i>群黑名单</div></div>
				<div class="card-content">
					<div class="input-group">
						<input type="text" class="input-field" id="new_group_black" placeholder="输入群号...">
						<button class="btn btn-danger" onclick="addGroupBlack()"><i class="fas fa-lock"></i>屏蔽</button>
					</div>
					<div class="list-container" id="group-blacklist"></div>
				</div>
			</div>
		</div>

		<div class="page" id="page-send">
			<div class="card">
				<div class="card-header"><div class="card-title"><i class="fas fa-paper-plane"></i>快速发信</div></div>
				<div class="card-content">
					<select id="send-qq" style="width:100%;padding:10px;margin-bottom:12px;background:var(--bg-input);border:1px solid var(--border);color:var(--text-primary);border-radius:6px;"></select>
					<input type="text" class="input-field" id="send-group" placeholder="群号" style="margin-bottom:10px;">
					<textarea class="textarea-field" id="send-text" placeholder="消息内容"></textarea>
					<button class="btn btn-primary" onclick="sendMessage()" style="width:100%;"><i class="fas fa-comment-dots"></i>发送</button>
				</div>
			</div>
		</div>

		<div class="page" id="page-ai">
			<div class="card">
				<div class="card-header"><div class="card-title"><i class="fas fa-comment-dots"></i>AI 智能助手</div></div>
				<div class="card-content">
					<div class="chat-container" id="ai-chat-log"><div class="empty-state"><i class="fas fa-robot"></i><p>开始与 AI 对话</p></div></div>
					<div class="chat-input-row">
						<input type="text" class="input-field" id="ai-question" placeholder="输入你的问题...">
						<button class="btn btn-primary" onclick="sendAIQuestion()"><i class="fas fa-paper-plane"></i>发送</button>
					</div>
					<div class="preview-box" id="ai-preview"></div>
				</div>
			</div>
		</div>

		<div class="page" id="page-update">
			<div class="card">
				<div class="card-header"><div class="card-title"><i class="fas fa-sync-alt"></i>检查更新</div><span class="update-status-badge up-to-date" id="update-status-badge"><i class="fas fa-check-circle"></i>已是最新</span></div>
				<div class="card-content">
					<div class="update-info">
						<div class="update-row"><span class="update-row-label">当前版本</span><span class="update-row-value" id="update-current">--</span></div>
						<div class="update-row"><span class="update-row-label">最新版本</span><span class="update-row-value" id="update-latest">--</span></div>
						<div class="update-row"><span class="update-row-label">检查时间</span><span class="update-row-value" id="update-time">未检查</span></div>
						<button class="btn btn-primary" onclick="doCheckUpdate()" id="update-btn"><i class="fas fa-sync-alt"></i>立即检查</button>
					</div>
				</div>
			</div>
			<div class="card" id="changelog-card" style="display:none;">
				<div class="card-header"><div class="card-title"><i class="fas fa-file-alt"></i>更新日志</div></div>
				<div class="card-content"><div class="update-changelog" id="update-changelog"></div></div>
			</div>
		</div>

		<div class="page" id="page-logs">
			<div class="card">
				<div class="card-header"><div class="card-title"><i class="fas fa-terminal"></i>实时日志</div><span style="font-size:12px;color:var(--text-secondary);">最近 50 条</span></div>
				<div class="card-content" style="padding-top:0;"><div class="log-container" id="log"></div></div>
			</div>
		</div>
	</main>

	<div class="toast" id="toast"><i class="fas fa-check-circle"></i><span id="toast-message"></span></div>

	<script>
		let allAccounts = [];
		let currentPluginQQ = null;

		function switchPage(id) {
			document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
			document.querySelectorAll('.nav-item[data-page]').forEach(n => n.classList.remove('active'));
			const page = document.getElementById('page-' + id);
			const nav = document.querySelector('.nav-item[data-page="' + id + '"]');
			if (page) page.classList.add('active');
			if (nav) nav.classList.add('active');
			const titles = {
				dashboard: ['fa-chart-line','仪表盘'],
				plugins: ['fa-puzzle-piece','插件管理'],
				permissions: ['fa-shield-alt','权限控制'],
				send: ['fa-paper-plane','快速发信'],
				accounts: ['fa-users-cog','账号管理'],
				ai: ['fa-comment-dots','AI 助手'],
				update: ['fa-sync-alt','检查更新'],
				logs: ['fa-terminal','实时日志']
			};
			const [icon, text] = titles[id] || ['fa-circle',''];
			document.getElementById('header-title').innerHTML = '<i class="fas ' + icon + '"></i>' + text;
			if (window.innerWidth <= 768) toggleSidebar(false);
		}

		function toggleSidebar(force) {
			const sidebar = document.getElementById('sidebar');
			const overlay = document.getElementById('overlay');
			if (force === false) { sidebar.classList.remove('open'); overlay.classList.remove('show'); }
			else { sidebar.classList.toggle('open'); overlay.classList.toggle('show'); }
		}

		function toggleTheme() {
			const html = document.documentElement;
			const icon = document.getElementById('theme-icon');
			if (html.getAttribute('data-theme') === 'dark') {
				html.setAttribute('data-theme', 'light'); icon.className = 'fas fa-moon';
			} else {
				html.setAttribute('data-theme', 'dark'); icon.className = 'fas fa-sun';
			}
		}

		function showToast(msg, type = 'success') {
			const toast = document.getElementById('toast');
			const icon = toast.querySelector('i');
			document.getElementById('toast-message').textContent = msg;
			icon.className = type === 'success' ? 'fas fa-check-circle toast-success' : 'fas fa-exclamation-circle toast-error';
			toast.classList.add('show');
			setTimeout(() => toast.classList.remove('show'), 3000);
		}

		async function fetchStatus() {
			try {
				const res = await fetch('/api/status');
				const data = await res.json();
				allAccounts = data.instances || [];
				document.getElementById('sidebar-qq').textContent = allAccounts.length ? allAccounts[0].qq : '--';
				const online = allAccounts.some(a => a.connected);
				document.getElementById('sidebar-status-dot').className = 'status-dot ' + (online ? 'online' : 'offline');
				document.getElementById('sidebar-status-text').textContent = online ? '在线' : '离线';
				document.getElementById('sidebar-version').textContent = data.current_version ? 'v'+data.current_version : '--';
				let html = '';
				allAccounts.forEach(bot => {
					html += `<div class="status-card">
						<div class="status-card-icon ${bot.conn